POSTGRES_DB=todo
POSTGRES_USER=todo
POSTGRES_PASSWORD=todo
API_IMAGE=ghcr.io/ogsupra/todo_list-api:latest
WEB_IMAGE=ghcr.io/ogsupra/todo_list-web:latest
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
SECRET_KEY=change-this-secret-key-with-at-least-32-characters
DATABASE_URL=postgresql+psycopg://todo:todo@postgres:5432/todo
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
CORS_ORIGINS=["http://localhost:8081","http://localhost:5173"]
MEDIA_ROOT=/app/media
SECURE_COOKIES=false
ADMIN_EMAILS=["admin@example.com"]
AUTH_RATE_LIMIT=20/minute
WRITE_RATE_LIMIT=80/minute
READ_RATE_LIMIT=240/minute
METRICS_ENABLED=false
GRAFANA_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
PGADMIN_URL=http://localhost:5050
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
WEB_CONCURRENCY=1
